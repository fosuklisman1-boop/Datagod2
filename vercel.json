{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["fra1", "iad1"],
  "functions": {
    "app/api/cron/sync-mtn-status/route.ts": { "maxDuration": 300 },
    "app/api/cron/sync-mtn-status/datakazina/route.ts": { "maxDuration": 300 },
    "app/api/cron/run-ai-tasks/route.ts": { "maxDuration": 300 },
    "app/api/cron/verify-pending-payments/route.ts": { "maxDuration": 120 },
    "app/api/cron/withdrawals-status-check/route.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/cron/sync-mtn-status",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-mtn-status/datakazina",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/verify-pending-payments",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/sync-codecraft-status",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/check-subscription-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/withdrawals-status-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/run-ai-tasks",
      "schedule": "* * * * *"
    }
  ]
}
